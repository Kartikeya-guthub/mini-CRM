generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Customer {
  id             String    @id @default(uuid()) @db.Uuid
  name           String?   @db.VarChar
  email          String    @unique @db.VarChar
  phone          String?   @db.VarChar
  city           String?   @db.VarChar
  total_spent    Decimal   @default(0) @db.Decimal
  last_order_at  DateTime? @db.Timestamp()
  order_count    Int       @default(0)
  created_at     DateTime  @default(now()) @db.Timestamp()

  orders         Order[]
  communications Communication[]
}

model Order {
  id                     String    @id @default(uuid()) @db.Uuid
  customer_id            String    @db.Uuid
  amount                 Decimal   @db.Decimal
  items                  Json
  status                 String    @db.VarChar // pending, completed, cancelled
  attributed_campaign_id String?   @db.Uuid
  created_at             DateTime  @default(now()) @db.Timestamp()

  customer               Customer  @relation(fields: [customer_id], references: [id])
  campaign               Campaign? @relation(fields: [attributed_campaign_id], references: [id])
}

model Segment {
  id                String     @id @default(uuid()) @db.Uuid
  name              String     @db.VarChar
  filter_definition Json       // the filter DSL
  customer_count    Int        @default(0) // cached on save
  created_at        DateTime   @default(now()) @db.Timestamp()

  campaigns         Campaign[]
}

model Campaign {
  id                String    @id @default(uuid()) @db.Uuid
  name              String    @db.VarChar
  segment_id        String    @db.Uuid
  message           String    @db.Text
  channel           String    @db.VarChar // whatsapp, sms, email, rcs
  status            String    @db.VarChar // draft, running, completed
  sent_count        Int       @default(0)
  delivered_count   Int       @default(0)
  failed_count      Int       @default(0)
  opened_count      Int       @default(0)
  clicked_count     Int       @default(0)
  attributed_orders Int       @default(0)
  created_at        DateTime  @default(now()) @db.Timestamp()

  segment           Segment   @relation(fields: [segment_id], references: [id])
  communications    Communication[]
  orders            Order[]
}

model Communication {
  id          String   @id @default(uuid()) @db.Uuid
  campaign_id String   @db.Uuid
  customer_id String   @db.Uuid
  channel     String   @db.VarChar
  message     String   @db.Text
  status      String   @db.VarChar // queued, sent, delivered, failed, opened, clicked
  created_at  DateTime @default(now()) @db.Timestamp()

  campaign    Campaign @relation(fields: [campaign_id], references: [id])
  customer    Customer @relation(fields: [customer_id], references: [id])
  events      CommunicationEvent[]
}

model CommunicationEvent {
  id               String   @id @default(uuid()) @db.Uuid
  communication_id String   @db.Uuid
  event_type       String   @db.VarChar // sent, delivered, failed, opened, clicked
  created_at       DateTime @default(now()) @db.Timestamp()

  communication    Communication @relation(fields: [communication_id], references: [id])

  @@unique([communication_id, event_type]) // idempotency constraint
}
