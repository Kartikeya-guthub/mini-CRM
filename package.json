{
  "name": "xeno-crm",
  "private": true,
  "workspaces": ["apps/*", "shared"],
  "scripts": {
    "dev": "concurrently \"npm run dev --workspace=apps/crm\" \"npm run dev --workspace=apps/channel\"",
    "build": "npm run build --workspace=apps/crm && npm run build --workspace=apps/channel",
    "start": "node server.js"
  },
  "devDependencies": {
    "concurrently": "^8.0.0"
  }
}
